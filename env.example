# ── SIMShield Environment Configuration ──
# Copy this file to .env and fill in your values
# Never commit .env to git

# ── Server ──
APP_ENV=development
APP_PORT=8000
APP_VERSION=1.0.0-hackathon

# ── Security ──
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-this-to-a-random-secret-before-demo
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# ── CAMARA / Nokia Network-as-Code ──
# Set MOCK_MODE=true to use scripted responses (no Nokia credentials needed)
# Set MOCK_MODE=false to hit real APIs (requires credentials below)
MOCK_MODE=true

NOKIA_API_BASE_URL=https://network-as-code.nokia.com
NOKIA_CLIENT_ID=your-client-id-here
NOKIA_CLIENT_SECRET=your-client-secret-here
NOKIA_TOKEN_URL=https://network-as-code.nokia.com/oauth2/token

# ── AI Orchestrator ──
ANTHROPIC_API_KEY=your-anthropic-api-key-here
AGENT_MODEL=claude-sonnet-4-20250514
AGENT_MAX_TOKENS=1000

# ── Database ──
DATABASE_URL=sqlite+aiosqlite:///./simshield.db

# ── CORS (Frontend origin) ──
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
